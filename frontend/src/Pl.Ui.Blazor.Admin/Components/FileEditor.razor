@typeparam TStorageService where TStorageService : IBaseStorageService

<MudStack Spacing="1" AlignItems="AlignItems.Center">

    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <MudText Typo="Typo.subtitle2">@Label</MudText>
    }

    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
    }
    else if (!string.IsNullOrWhiteSpace(_previewUrl))
    {
        <MudImage Src="@_previewUrl"
                  Alt="@AltText"
                  Width="280"
                  Height="180"
                  ObjectFit="ObjectFit.Cover" />
    }
    else
    {
        <MudText Typo="Typo.caption" Class="mud-text-secondary">
            Нет изображения
        </MudText>
    }

    <MudStack Direction="Row" Spacing="1" Justify="Justify.Center">

        <MudFileUpload T="IBrowserFile"
                       MaxFiles="1"
                       Disabled="_loading"
                       FilesChanged="OnFileChangedAsync">

            <ActivatorContent>
                <MudButton Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Upload"
                           Disabled="_loading">
                    Загрузить
                </MudButton>
            </ActivatorContent>

        </MudFileUpload>

        <MudButton Variant="Variant.Outlined"
                   Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.Delete"
                   Disabled="_loading || string.IsNullOrWhiteSpace(Key)"
                   OnClick="OnDeleteClickedAsync">
            Удалить
        </MudButton>

    </MudStack>

    @if (ShowKey && !string.IsNullOrWhiteSpace(Key))
    {
        <MudText Typo="Typo.caption">Key: @Key</MudText>
    }

</MudStack>
